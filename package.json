{
  "name": "lingoleaf",
  "version": "0.1.2",
  "private": true,
  "description": "LingoLeaf browser extension (Chrome MV3) — French learning helper with local AI",
  "license": "MIT",
  "keywords": ["chrome-extension", "manifest-v3", "language-learning"],
  "scripts": {
    "test": "node --test --test-only extension/lib/*.test.js",
    "test:all": "node --test extension/lib/*.test.js",
    "test:watch": "node --test --test-only --watch extension/lib/*.test.js",
    "test:all:watch": "node --test --watch extension/lib/*.test.js",
    "test:one": "node --test",
    "test:one:focus": "node --test --test-only"
  },
  "engines": {
    "node": ">=20.13"
  }
}
